# LexUg .gitignore
# Never commit sensitive files

# Environment variables
.env
.env.local
.env.*.local

# API Keys (don't commit real keys!)
*.key
*.pem
*.p12

# Node/Package files (if we add backend later)
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
.next/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# OS files
.DS_Store
Thumbs.db
**/._*

# Test files
coverage/
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*

# Temporary files
*.tmp
*.temp
.tmp/

# Don't commit local config
config.local.js
